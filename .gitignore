# =========================
# Python cache
# =========================
__pycache__/
*.pyc
*.pyo

# =========================
# Jupyter checkpoints
# =========================
.ipynb_checkpoints/

# =========================
# Virtual environments
# =========================
venv/
env/

# =========================
# Dataset files (ignore large data)
# =========================
*.csv
*.zip
data/

# =========================
# Model files
# Ignore ALL models EXCEPT those in Models/
# =========================
*.pkl
*.joblib
!Models/
!Models/*.pkl
!Models/*.joblib

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db
